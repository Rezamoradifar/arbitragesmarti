# ============================================================
# ArbiSmartV2 — Polygon mainnet deployment configuration
# Copy this file to `.env` and fill in real values.
# NEVER commit the real `.env` file (it already is git-ignored).
# ============================================================

# --- Network -------------------------------------------------
# Polygon mainnet (chain id 137) RPC endpoint. A private RPC provider
# (Alchemy/Infura/QuickNode) is strongly recommended over public endpoints
# for production deployments (rate limits, reliability).
POLYGON_RPC_URL=https://polygon-rpc.com

# --- Deployer --------------------------------------------------
# Private key of the deploying account, 0x-prefixed. This account only
# needs to pay gas for the deployment transaction — it does NOT need to be,
# and for production should NOT be, the contract's owner (see INITIAL_OWNER
# below). Use a dedicated, funded-only-as-needed deployer key; never reuse
# a key that also holds significant funds elsewhere.
PRIVATE_KEY=0xyour_deployer_private_key_here

# --- Constructor arguments ------------------------------------
# Collateral ERC-20 token address. MUST be the exact token address that the
# Polymarket condition(s) you intend to interact with were prepared with.
COLLATERAL_TOKEN=0x0000000000000000000000000000000000000000

# STRONGLY RECOMMENDED: set this to a Gnosis Safe multisig address or an
# OpenZeppelin TimelockController address, NOT a bare EOA. This address
# receives full owner privileges (pause, blacklist, fee wallet changes,
# and triggering Polymarket split/merge/redeem calls).
INITIAL_OWNER=0x0000000000000000000000000000000000000000

FEE_WALLET_1=0x0000000000000000000000000000000000000000
FEE_WALLET_2=0x0000000000000000000000000000000000000000

# Recipient of the performance fee charged on REAL, realized Polymarket
# arbitrage profit (see profitFeeBPS / executePolymarketRedeem in the
# contract). Distinct wallet from FEE_WALLET_1/2 above, which are funded
# from staking-yield claims instead. Defaults to a 10% fee, owner-adjustable
# post-deploy up to a hard-coded 20% cap.
PROFIT_RECIPIENT=0x0000000000000000000000000000000000000000

# --- PolygonScan verification -----------------------------------
# API key from https://polygonscan.com/myapikey
POLYGONSCAN_API_KEY=your_polygonscan_api_key_here
